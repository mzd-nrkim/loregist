#!/usr/bin/env bash
# 중앙 stashdex CLI 래퍼
_SELF="${BASH_SOURCE[0]}"
# 심볼릭 링크를 따라 실제 스크립트 위치 해석
while [ -L "$_SELF" ]; do
  _SELF="$(readlink "$_SELF")"
done
SCRIPT_DIR="$(cd "$(dirname "$_SELF")" && pwd)"
PYTHON="$SCRIPT_DIR/.venv/bin/python"

if [ ! -f "$PYTHON" ]; then
  echo "오류: venv 없음. $SCRIPT_DIR/.venv 에 venv를 생성하세요." >&2
  exit 1
fi

export PYTHONPATH="$SCRIPT_DIR/src"

subcmd="$1"
shift

export LOREGIST_CWD="$PWD"

case "$subcmd" in
  embed)
    cd "$SCRIPT_DIR" && exec "$PYTHON" -m loregist.embed "$@"
    ;;
  search)
    cd "$SCRIPT_DIR" && exec "$PYTHON" -m loregist.search "$@"
    ;;
  project)
    cd "$SCRIPT_DIR" && exec "$PYTHON" -m loregist.project_cmd "$@"
    ;;
  rotate)
    cd "$SCRIPT_DIR" && exec "$PYTHON" -m loregist.rotate "$@"
    ;;
  status)
    cd "$SCRIPT_DIR" && exec "$PYTHON" -m loregist.status "$@"
    ;;
  similar)
    cd "$SCRIPT_DIR" && exec "$PYTHON" -m loregist.similar "$@"
    ;;
  vault-cleanup)
    cd "$SCRIPT_DIR" && exec "$PYTHON" -m loregist.vault_cleanup "$@"
    ;;
  catalog-init)
    cd "$SCRIPT_DIR" && exec "$PYTHON" -m loregist.catalog_gen init "$@"
    ;;
  catalog)
    cd "$SCRIPT_DIR" && exec "$PYTHON" -m loregist.catalog_gen run "$@"
    ;;
  warmup)
    cd "$SCRIPT_DIR" && exec "$PYTHON" -m loregist.warmup "$@"
    ;;
  journal)
    cd "$SCRIPT_DIR" && exec "$PYTHON" -m loregist.journal "$@"
    ;;
  memo)
    cd "$SCRIPT_DIR" && exec "$PYTHON" -m loregist.memo "$@"
    ;;
  watch)
    cd "$SCRIPT_DIR" && exec "$PYTHON" -m loregist.watch "$@"
    ;;
  *)
    echo "사용법: stashdex <embed|search|project|rotate|status|similar|vault-cleanup|catalog-init|catalog|warmup|journal|memo|watch> [옵션]"
    echo "  embed         [--project P] [--dry-run] [--include-today]  문서/로그 임베딩"
    echo "  search        <쿼리> [--top-k N] [--project P] [--all-projects] [--plain|--json|--open N|--no-interactive]  시맨틱 검색"
    echo "  project       <add|list|current>            프로젝트 그룹 커맨드 (온보딩·목록·현재 추론)"
    echo "  rotate        [--project P] [--dry-run] [--extensions md,log,txt]   7일 초과 날짜폴더 → vault 이동 (임베딩 전제)"
    echo "  status                                     프로젝트별 임베딩 현황 대시보드"
    echo "  similar       <파일경로> [--top-k N]       특정 파일과 유사한 과거 문서 찾기"
    echo "  vault-cleanup [--project P] [--dry-run|--apply]  vault/cold 파일 DB 대조 후 정리"
    echo "  catalog-init  --project <키>  [--force]    _wiki/ 초기화 (TOPICS.md·DECISIONS.md 생성)"
    echo "  catalog       --project <키>               _wiki/TOPICS.md·DECISIONS.md 재생성"
    echo "  warmup                                     임베딩 모델 사전 다운로드·캐시 (최초 1회)"
    echo "  journal       <메시지> [--project P]       오늘 날짜 로그 파일에 [HH:MM] 메시지 기록"
    echo "  memo          <메시지> [--project P]  메시지 단위 독립 파일로 저장"
    echo "  watch         [--dir DIR] [--project P]    디렉터리 감시 → *.log / *.md 변경 시 자동 embed"
    exit 1
    ;;
esac
