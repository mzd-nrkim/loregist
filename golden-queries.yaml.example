# golden-queries.yaml — 골든 쿼리 평가셋 예시
#
# 실 파일(golden-queries.yaml)은 .gitignore에 등록되어 있습니다.
# 이 파일을 복사해 golden-queries.yaml을 만들고, 실제 쿼리·경로·프로젝트명으로 수정하세요:
#   cp golden-queries.yaml.example golden-queries.yaml
#
# 스키마:
#   queries:            최상위 리스트
#     - query: str      검색어 (필수)
#       project: str    대상 프로젝트명, projects.toml의 PROJECTS 키와 일치 (필수)
#       expected_paths:  기대 결과 경로 리스트; 부분 매칭(in) 판정 (필수)
#         - str
#       note: str       설명 (선택)
#
# 사용법:
#   loregist eval
#   loregist eval --golden golden-queries.yaml --rrf-k 60

queries:
  # --- 약어/정확 키워드 (vector 단독 취약, fts/hybrid가 잡아야 함) ---
  - query: "api"
    project: project-a
    expected_paths:
      - "api-spec"
      - "api-guide"
    note: 약어 — vector 의미검색 취약, fts/hybrid로 잡혀야 함

  - query: "sdk"
    project: project-b
    expected_paths:
      - "sdk-setup"
    note: 약어 sdk

  # --- 약어 + 의미 혼합 ---
  - query: "API 연동 가이드"
    project: project-a
    expected_paths:
      - "api-integration-guide"
    note: 약어와 의미가 섞인 케이스 — hybrid 강점 구간

  # --- 의미 쿼리 (vector 강점) ---
  - query: "배포 파이프라인 테스트"
    project: project-a
    expected_paths:
      - "deploy-pipeline-test"
    note: 의미 검색 — vector/hybrid가 잡아야 함

  - query: "데이터 구조 조사"
    project: project-b
    expected_paths:
      - "data-structure-survey"
    note: 의미 검색 — 표현 변형 허용
